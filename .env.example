# ==============================================================
# 敏感配置示例文件 — 复制为 .env 并填入真实值后使用
# .env 已被 .gitignore 排除，不会被提交到代码仓库
# ==============================================================

# ---------------------------------------------------------------
# Tushare Pro（日线数据备用源 & 情绪指数备用）
# 免费注册：https://tushare.pro/register
# ---------------------------------------------------------------
TUSHARE_TOKEN=your_tushare_pro_token_here

# ---------------------------------------------------------------
# JoinQuant 聚宽（情绪指数备用源，可选）
# 免费注册：https://www.joinquant.com/
# 二选一：账号密码 或 access_token
# ---------------------------------------------------------------
JQ_USER=your_joinquant_username
JQ_PASSWORD=your_joinquant_password
# JQ_ACCESS_TOKEN=your_joinquant_access_token   # 与账号密码二选一

# ---------------------------------------------------------------
# 财联社 CLS（资讯 API，news_fetcher & policy_news 使用，可选）
# 申请：https://www.cls.cn/
# ---------------------------------------------------------------
CLS_API_KEY=your_cls_api_key_here

# ---------------------------------------------------------------
# AI 大模型（ai_analyst.py 调用 LLM 进行政策/新闻分析，可选）
# 兼容 OpenAI 接口的任意服务（DeepSeek / 月之暗面 / 本地 Ollama 等）
# ---------------------------------------------------------------
AI_API_KEY=your_ai_api_key_here
AI_BASE_URL=https://api.openai.com/v1   # 或替换为其他兼容服务地址
AI_MODEL=gpt-4o-mini                    # 或 deepseek-chat / moonshot-v1-8k 等

# ---------------------------------------------------------------
# 使用说明
# ---------------------------------------------------------------
# 1. cp .env.example .env
# 2. 编辑 .env，填入真实 token/key
# 3. 代码会自动读取，例如：
#      os.environ.get("TUSHARE_TOKEN")
#      os.environ.get("AI_API_KEY")
# 4. 也可将 tushare_token 写入 config/trading_config.yaml 的
#    data.tushare_token 字段（代码优先读 config，再读环境变量）
# 5. 所有 key 均为可选项，缺失时对应数据源自动跳过，不影响核心功能
