# 配置文件（包含敏感信息）
config/trading_config.yaml
config/risk_config.yaml
config/strategy_config.yaml
config/broker_config.yaml
config/strategy_rules.yaml
*.secret

# 数据文件（新目录结构）
mydate/
!mydate/.gitkeep
mycache/
!mycache/.gitkeep
mylog/
!mylog/.gitkeep
myoutput/
!myoutput/.gitkeep

# 数据文件（旧目录，保留兼容）
data/
!data/.gitkeep
data/market_data/*.csv
data/market_data/*.h5
data/market_data/*.parquet
data/factor_data/*.csv
data/factor_data/*.h5
data/models/*.pkl
data/models/*.h5
data/models/*.pth

# 日志文件（旧目录，保留兼容）
logs/
!logs/.gitkeep
logs/*.log
logs/*.txt

# 个人交易记录（敏感）
# 注意：mydate/ 目录已在上方忽略，这里只处理根目录的敏感JSON
mydate/*.json
!mydate/.gitkeep
!mydate/stock_pool*.json.example
!package.json
!tsconfig.json

# 模拟交易数据（包含个人信息）
paper_trading_*.json
account_*.json

# 输出文件
output/
!output/.gitkeep

# 缓存（旧目录，保留兼容）
cache/
.cache/
GPUCache/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# 测试
.pytest_cache/
.coverage
htmlcov/
.tox/

# 文档构建
docs/_build/

# 临时文件
*.tmp
*.bak
*.swp

# 安装包（体积大，不应提交）
*.deb
*.rpm
*.exe
*.msi
*.dmg
